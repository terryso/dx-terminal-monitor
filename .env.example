# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 允许使用的 Telegram 用户 ID (逗号分隔，可选)
ALLOWED_USERS=

# Terminal Markets Vault 地址
VAULT_ADDRESS=your_vault_address_here

# API 基础 URL
API_BASE_URL=https://api.terminal.markets/api/v1

# Ethereum RPC 端点 (Infura/Alchemy/自建)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key

# 钱包私钥 (用于签署合约交易，请务必保密!)
# 警告: 永远不要将真实私钥提交到 Git
PRIVATE_KEY=your_private_key_here

# 链 ID (1=mainnet, 11155111=sepolia, 17000=holesky)
CHAIN_ID=1

# 管理员用户 ID (用于高风险操作，逗号分隔)
ADMIN_USERS=

# Test Environment
TEST_ENV=local
TEST_USER_ID=123456789

# Activity Monitor Configuration
# Polling interval in seconds (minimum 10, default 30)
POLL_INTERVAL=30

# Activity Notification Configuration
# User IDs to receive activity notifications (comma-separated)
# If not configured, will use ADMIN_USERS or ALLOWED_USERS as fallback
NOTIFY_USERS=

# Monitor Control Configuration
# Whether to auto-start monitor on bot startup (true/false, default: true)
AUTO_START_MONITOR=true

# Daily Report Configuration
# Time to send daily report in HH:MM format (UTC, default: 08:00)
REPORT_TIME=08:00
# Whether to enable daily report feature (true/false, default: true)
REPORT_ENABLED=true

# Threshold Alert Configuration
# PnL change percentage threshold for alerts (default: 5%)
PNL_ALERT_THRESHOLD=5
# Position value change percentage threshold for alerts (default: 10%)
POSITION_ALERT_THRESHOLD=10
# Alert check interval in seconds (minimum 30, default: 60)
ALERT_CHECK_INTERVAL=60
# Whether to enable threshold alerts (true/false, default: true)
ALERT_ENABLED=true

# LLM Configuration (for AI Strategy Advisor - Epic 8)
# API key for LLM service (GLM-4, OpenAI, DeepSeek, etc.)
LLM_API_KEY=your_api_key_here
# Base URL for LLM API endpoint (default: GLM-4 endpoint)
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Model to use for chat completions (default: glm-4)
LLM_MODEL=glm-4
# Request timeout in seconds (default: 60)
LLM_TIMEOUT=60

# AI Strategy Advisor Configuration (Epic 8)
# Whether to enable AI strategy advisor (true/false, default: true)
ADVISOR_ENABLED=true
# Interval in hours between AI analysis runs (default: 2)
ADVISOR_INTERVAL_HOURS=2
# TTL for pending suggestions in minutes (default: 30)
SUGGESTION_TTL_MINUTES=30
